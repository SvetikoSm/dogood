# Дублирование заявок в Google (Таблица + Диск). Подробно: scripts/google-apps-script-order-webapp.gs
#
# Скопируйте этот файл в .env.local в корне проекта и подставьте значения.
# WEBHOOK_SECRET на сайте = WEBHOOK_SECRET в Script properties в Google.

# URL из Deploy → Web app (script.google.com)
GOOGLE_ORDER_WEBHOOK_URL=

# Та же строка, что свойство WEBHOOK_SECRET в Apps Script
GOOGLE_ORDER_WEBHOOK_SECRET=
